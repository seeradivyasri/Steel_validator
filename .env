DATABASE_URL=sqlite:///./steel_validation.db
EXPORT_FOLDER_PATH=./data/exports
ARCHIVE_FOLDER_PATH=./data/archive
FAILED_FOLDER_PATH=./data/failed
SUPPRESSION_THRESHOLD_KG=5
ADMIN_SECRET_TOKEN=changeme

# ── AI Alias Learning Engine ──────────────────────────────────────────────
# Hugging Face is only used once — to download the model file.
# After download, the AI runs 100% offline. Hugging Face is never used again.
AI_MODEL_PATH=./models/phi-3-mini-4k-instruct-q4.gguf
AI_ENABLED=true
AI_N_CTX=2048
AI_N_THREADS=4
AI_MAX_TOKENS=80
AI_TIMEOUT_SECONDS=10
# ─────────────────────────────────────────────────────────────────────────
